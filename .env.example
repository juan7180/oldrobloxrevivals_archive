# copy to apps/web/.env.local

NEXT_PUBLIC_APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Chunked archive directory (default: <repo>/data/archive)
# ARCHIVE_DIR=/absolute/path/to/data/archive

# Legacy single-file archive if meta.json is missing
# ARCHIVE_PATH=/absolute/path/to/data/archive.json

# MEDIA_ROOT=/absolute/path/to/media
