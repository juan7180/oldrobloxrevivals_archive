# Copy to apps/web/.env.local (or repo root — Next loads from apps/web when you run dev there)

# Public app URL used for server-side fetch to /api routes (default: http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated origins allowed by Elysia CORS (browser calls from another host)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional absolute paths (defaults: <repo>/data/archive.json and <repo>/media)
# ARCHIVE_PATH=/absolute/path/to/data/archive.json
# MEDIA_ROOT=/absolute/path/to/media
